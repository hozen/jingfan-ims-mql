9-b842cd83bcb3/SsHlGA/WQ/Footer/aquaticInformaticsLogo.png?mw=120&amp;sh=48c9c" alt="Aquatic Informatics logo" /></a>    <a href="https://www.chemtreat.com/" target="_blank"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/425fe2c1-4074-468f-83bc-84e9e85230b1/eWQCuA/WQ/Footer/ChemTreat-Logo.png?mw=120&amp;sh=119e1" alt="ChemTreat logo" title="ChemTreat logo" /></a>   <a href="https://www.hach.com/" target="_blank"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/2bd89913-909e-4f13-badb-a69b8577132a/EJgK3g/WQ/Footer/logo-hach.png?mw=120&amp;sh=b1b29" alt="Hach logo" title="Hach logo" /></a>   <a href="https://www.mccrometer.com/" target="_blank"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/b2150f93-6a84-4d43-849c-aefe2dcf1b95/bZ0W4g/WQ/Footer/McCrometer_Logo_300dpi_GreyCirle_BlueLogo_No_Background.gif?mw=120&amp;sh=c730a" alt="McCrometer logo" title="McCrometer logo" /></a>   </p><div style="margin-bottom:20px"></div><p class="text-center"><a href="https://www.otthydromet.com/en/"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/cbfeaee0-f5df-41a7-bf57-e7ed5e27479f/1aOZUg/WQ/Footer/logo-ott.png?mw=120&amp;sh=c1185" alt="OTT HyroMet logo" title="OTT HyroMet logo" /></a>    <a href="https://www.seabird.com/" target="_blank"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/17ce6093-14ab-4c11-b372-8796f0ebae28/v4SJgw/WQ/Footer/logo-sea-bird-scientific-logo-140x49.png?mw=120&amp;sh=d200b" alt="Sea-Bird Scientific logo" title="Sea-Bird Scientific logo" /></a>   <a href="https://www.trojantechnologies.com/"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/37516265-de8d-4baf-bdbc-ef96e588c1a2/VfR8Vw/WQ/Footer/logo-trojan.png?mw=120&amp;sh=f104a" alt="Trojan Technologies logo" title="Trojan Technologies logo" /></a>    <a href="https://www.xos.com/" target="_blank"><img src="//dhwaterquality-prd-cdn.azureedge.net/media/ebd426b3-8cdb-4c98-bc63-aaae6a206feb/XoRJVA/WQ/Footer/XOS_logo_Blue_PMS.png?mw=100&amp;sh=e24b3" alt="XOS logo" title="XOS logo" /></a></p><div style="margin-bottom:30px"></div><div class="full-width layout-compo bg-gray-900" style="padding:20px 0; margin-top:0px; margin-bottom:0px;"><div class="container text-light"><div style="margin-bottom:10px"></div><p class="text-center p-small"><a class="text-gray-100" href="/policies/privacy-policy">Privacy Policy</a>  |  <a class="text-gray-100" href="/policies/cookienotice">Cookie Policy</a>  |  <a class="text-gray-100" href="javascript:Optanon.ToggleInfoDisplay()" style="cursor: pointer !important;" data-mce-style="cursor: pointer !important;">Cookies Settings</a>   |  <a class="text-gray-100" href="/policies/ccpa">Do Not Sell or Share My Data</a></p><div style="margin-bottom:30px"></div></div></div><script type="text/javascript">
//<![CDATA[
(function() {
  const RELOAD_KEY = "errorReloadCount";
  const MAX_RELOADS = 3;
  const RELOAD_DELAY_MS = 1000;

  const PAGE_TITLE_TARGET = "Product | Hach";
  const RECHECK_DELAY_MS = 5000; // re-check title after 5 seconds

  function shouldRun() {
    const currentTitle = (document.title || "").trim();
    return currentTitle === PAGE_TITLE_TARGET;
  }

  function maybeReload() {
    const reloadCount = parseInt(sessionStorage.getItem(RELOAD_KEY) || "0", 10);

    if (reloadCount < MAX_RELOADS) {
      console.warn(`On '${PAGE_TITLE_TARGET}' — reloading page in 1s (attempt ${reloadCount + 1}/${MAX_RELOADS})`);
      sessionStorage.setItem(RELOAD_KEY, reloadCount + 1);

      // Push analytics event ONLY when a reload will occur
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'event': 'errorPageReload',
        reloadCount: reloadCount
      });

      setTimeout(() => location.reload(), RELOAD_DELAY_MS);
    } else {
      console.warn("Maximum reload attempts reached — not reloading again.");
    }
  }

  // Immediate check
  if (shouldRun()) {
    maybeReload();
  } else {
    sessionStorage.removeItem(RELOAD_KEY);

    // Single delayed re-check after possible async title update
    setTimeout(() => {
      if (shouldRun()) {
        maybeReload();
      } else {
        sessionStorage.removeItem(RELOAD_KEY);
      }
    }, RECHECK_DELAY_MS);
  }
})();
//]]></script><div style="margin-bottom:-40px"></div></div><div class="optional-footer-links"><div class="container"><ul class="nav nav-legal"><li class="copyright"><span>
